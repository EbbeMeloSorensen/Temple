<UserControl x:Class="Temple.UI.WPF.DD.Wilderness.WildernessView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Temple.UI.WPF.DD.Wilderness"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignData WildernessViewModel}">
    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <Button Margin="10" Width="130" Content="Go to Mine" Command="{Binding GoToSite_Mine_Command}"/>
            <Button Margin="10" Width="130" Content="Go to Village" Command="{Binding GoToSite_Village_Command}"/>
            <Button Margin="10" Width="130" Content="Go to Graveyard" Command="{Binding GoToSite_Graveyard_Command}"/>
            <Button Margin="10" Width="130" Content="Go to Maze" Command="{Binding GoToSite_Maze_Command}"/>
            <Button Margin="10" Width="130" Content="Go to Undermountain" Command="{Binding GoToSite_Undermountain_Command}"/>
        </StackPanel>

        <ListBox Grid.Column="1"
                 ItemsSource="{Binding Sites}"
                 SelectedItem="{Binding SelectedSite}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Text}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Grid.Column="0" Grid.ColumnSpan="2"
                Content="In-Game Menu" Width="120" Height ="30"
                VerticalAlignment="Top" HorizontalAlignment="Right" Margin="20"
                Command="{Binding GoToInGameMenu_Command}"/>
    </Grid>
</UserControl>
